
alt - b : open -a Arc
alt - t : open -a Kitty
alt - s : open -a Spotify
alt - p : open -a Preview
alt - c : open -a Calendar
alt - m : open -a Mail
alt - l : open -a Slack
alt - f : open -a Finder
alt - a : open -a Activity\ Monitor

alt + cmd - left : yabai -m window --grid 1:2:0:0:1:1
alt + cmd - right : yabai -m window --grid 1:2:1:0:1:1
alt + cmd - up : yabai -m window --grid 1:1:0:0:1:1
alt - down : osascript -e 'tell application "System Events" to keystroke "m" using {command down}'

alt - left  : yabai -m window --focus west
alt - down  : yabai -m window --focus south
alt - up    : yabai -m window --focus north
alt - right : yabai -m window --focus east


alt + cmd - b : yabai -m space --layout bsp
alt + cmd - s : yabai -m space --layout stack
alt + cmd - f : yabai -m space --layout float

